# Leave this UNSET for local/Codespaces/Gitpod dev — the Vite dev server
# proxies /api/* to the Express server automatically (see vite.config.ts),
# so relative requests just work regardless of hostname or port forwarding.
#
# Only set this for a PRODUCTION build, where the client and server are
# deployed as separate origins:
# VITE_API_URL=https://api.yourdomain.com
