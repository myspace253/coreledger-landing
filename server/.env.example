# --- Server ---
PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# --- AI provider (OpenAI-compatible chat completions endpoint) ---
# Works with TokenRouter (https://tokenrouter.com), OpenRouter, or any
# OpenAI-compatible gateway. Swap AI_BASE_URL / AI_MODEL accordingly.
AI_BASE_URL=https://api.tokenrouter.com/v1
AI_API_KEY=your_tokenrouter_or_openrouter_api_key
AI_MODEL=minimax-m3

# --- Market / developer / social data ---
# src/services/marketData.ts pulls real price, market cap, supply, GitHub
# developer activity, and social-follower data from CoinGecko's public API.
# No key required — nothing to set here for that data to go live.

# --- On-chain holder/liquidity providers (optional) ---
# Used by src/services/onchainData.ts. Holder concentration, whale flow, and
# liquidity-locked % have no genuinely free data source (Etherscan's holder
# endpoint is gated behind their paid plans), so these stay simulated until
# you wire in a keyed provider here. Leave blank to keep using the built-in
# deterministic mock generator for this section only — market/dev/social data
# above is unaffected either way.
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=
MORALIS_API_KEY=
