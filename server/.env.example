# --- Server ---
PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# --- AI provider (OpenAI-compatible chat completions endpoint) ---
# Works with TokenRouter (https://tokenrouter.com), OpenRouter, or any
# OpenAI-compatible gateway. Swap AI_BASE_URL / AI_MODEL accordingly.
AI_BASE_URL=https://api.tokenrouter.com/v1
AI_API_KEY=your_tokenrouter_or_openrouter_api_key
AI_MODEL=minimax-m3

# --- On-chain / market data providers ---
# Used by src/services/onchainData.ts to fetch real holder, liquidity,
# and dev-activity data before it's handed to the AI for reasoning.
# Leave blank to fall back to the built-in mock data generator.
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=
MORALIS_API_KEY=
GITHUB_TOKEN=
